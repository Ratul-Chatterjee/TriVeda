generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id                   String               @id @default(uuid())
  email                String?              @unique
  phoneNumber          String?              @unique
  password             String?
  name                 String
  isAppRegistered      Boolean              @default(false)
  age                  Int?
  gender               String?
  bloodGroup           String?
  prakriti             String?
  vikriti              String?
  vataScore            Int?
  pittaScore           Int?
  kaphaScore           Int?
  allergies            String[]             @default([])
  dietaryPref          String?
  clinicalData         Json?
  createdAt            DateTime             @default(now())
  dateOfBirth          DateTime?
  profileImageData     Bytes?
  profileImageMimeType String?
  appointments         Appointment[]
  treatmentPlans       TreatmentPlan[]
  reports              PatientReport[]
  assessments          PrakritiAssessment[]
}

model PatientReport {
  id        String   @id @default(uuid())
  patientId String
  fileName  String
  mimeType  String
  sizeBytes Int
  fileData  Bytes
  summary   String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model PrakritiAssessment {
  id           String   @id @default(uuid())
  patientId    String
  answer1      String
  answer2      String
  answer3      String
  answer4      String
  answer5      String
  answer6      String
  answer7      String
  answer8      String
  vataScore    Int
  pittaScore   Int
  kaphaScore   Int
  primaryDosha String
  timeSpentSec Int?
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model HospitalStaff {
  id                String            @id @default(uuid())
  email             String            @unique
  password          String
  name              String
  role              StaffRole
  hospitalId        String
  createdAt         DateTime          @default(now())
  age               Int?
  dateOfBirth       DateTime?
  gender            String?
  appointmentsAsDoc Appointment[]
  treatmentPlans    TreatmentPlan[]
  doctorProfile     DoctorProfile?
  hospital          Hospital          @relation(fields: [hospitalId], references: [id])
  therapistProfile  TherapistProfile?
}

model DoctorProfile {
  id             String        @id @default(uuid())
  specialty      String
  experienceYrs  Int
  isAvailable    Boolean       @default(true)
  departmentId   String?
  staffId        String        @unique
  languages      String[]      @default([])
  caseSummaries  String[]      @default([])
  education      String[]      @default([])
  qualifications String[]      @default([])
  locality       String?
  certificates   String?
  previousWork   String?
  extraInfo      String?
  department     Department?   @relation(fields: [departmentId], references: [id])
  staff          HospitalStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model TherapistProfile {
  id             String        @id @default(uuid())
  staffId        String        @unique
  certifications String[]      @default([])
  staff          HospitalStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Hospital {
  id      String          @id @default(uuid())
  name    String
  address String?
  staff   HospitalStaff[]
}

model Department {
  id          String          @id @default(uuid())
  name        String
  description String?
  doctors     DoctorProfile[]
}

model Appointment {
  id                 String            @id @default(uuid())
  patientId          String
  doctorId           String
  scheduledAt        DateTime
  status             AppointmentStatus @default(SCHEDULED)
  patientSymptoms    String?
  aiSummary          String?
  createdAt          DateTime          @default(now())
  diagnosis          Json?
  dietChart          Json?
  doctorNotes        String?
  isCompleted        Boolean           @default(false)
  medications        Json?
  routinePlan        Json?
  paymentStatus      String            @default("PENDING")
  problemDescription String?
  severity           String?
  duration           String?
  doctor             HospitalStaff     @relation(fields: [doctorId], references: [id])
  patient            Patient           @relation(fields: [patientId], references: [id])
  treatmentPlan      TreatmentPlan?
}

model TreatmentPlan {
  id           String                @id @default(uuid())
  appointmentId String               @unique
  patientId    String
  doctorId     String
  doctorNotes  String?
  diagnosis    Json?
  dietChart    Json?
  routinePlan  Json?
  isCompleted  Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  appointment  Appointment           @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor       HospitalStaff         @relation(fields: [doctorId], references: [id])
  patient      Patient               @relation(fields: [patientId], references: [id])
  dietPlan     DietPlan?
  medications  TreatmentMedication[]

  @@index([patientId, createdAt])
  @@index([doctorId, createdAt])
}

model DietPlan {
  id              String     @id @default(uuid())
  treatmentPlanId String     @unique
  title           String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  items           DietItem[]
}

model DietItem {
  id         String   @id @default(uuid())
  dietPlanId String
  mealTime   MealTime @default(OTHER)
  itemName   String
  notes      String?
  isAvoid    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  @@index([dietPlanId, mealTime])
}

model TreatmentMedication {
  id              String        @id @default(uuid())
  treatmentPlanId String
  name            String
  dosage          String?
  timing          String?
  medicineType    String?
  durationDays    Int?
  doctorNotes     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)

  @@index([treatmentPlanId, createdAt])
}

model foods {
  food_id        String           @id
  food_name      String
  category       String?
  serving_size   Int?
  calories       Int?
  protein        Int?
  carbs          Int?
  fat            Int?
  vit_c          Int?
  iron           Int?
  preparation    String?
  ayurveda_props ayurveda_props[]

  @@index([category], map: "idx_foods_category")
  @@index([food_name], map: "idx_foods_name")
}

model ayurveda_props {
  id           Int     @id
  food_id      String
  rasa         String?
  virya        String?
  vipaka       String?
  gunas        String?
  dosha_impact String?
  foods        foods   @relation(fields: [food_id], references: [food_id])

  @@index([food_id], map: "idx_ayurveda_props_food_id")
}

model asanas {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String   @unique(map: "asanas_name_unique")
  category             String?
  ayurvedic_properties String[] @default([])
  effect_profile       String[] @default([])
  contraindications    String[] @default([])
  notes                String?
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)

  @@index([is_active, name], map: "idx_asanas_active_name")
  @@index([category], map: "idx_asanas_category")
}

model medicines {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  medicine_name        String   @unique(map: "medicines_name_unique")
  medicine_type        String?
  herbs_used           String[] @default([])
  ayurvedic_properties String[] @default([])
  dosage_guideline     String?
  contraindications    String[] @default([])
  notes                String?
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)

  @@index([is_active, medicine_name], map: "idx_medicines_active_name")
  @@index([medicine_type], map: "idx_medicines_type")
}

enum StaffRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
  NURSE
  THERAPIST
  BILLING
}

enum AppointmentStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum MealTime {
  EARLY_MORNING
  BREAKFAST
  MID_MORNING
  LUNCH
  EVENING
  DINNER
  OTHER
}
