generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id              String        @id @default(uuid())
  email           String?       @unique
  phoneNumber     String?       @unique
  password        String?
  name            String
  isAppRegistered Boolean       @default(false)
  age             Int?
  dateOfBirth     DateTime?
  gender          String?
  bloodGroup      String?
  profileImageData Bytes?
  profileImageMimeType String?
  prakriti        String?
  vikriti         String?
  vataScore       Int?
  pittaScore      Int?
  kaphaScore      Int?
  allergies       String[]      @default([])
  dietaryPref     String?
  clinicalData    Json?
  createdAt       DateTime      @default(now())
  appointments    Appointment[]
  assessments     PrakritiAssessment[]
  reports         PatientReport[]
}

model PatientReport {
  id         String   @id @default(uuid())
  patientId  String
  fileName   String
  mimeType   String
  sizeBytes  Int
  fileData   Bytes
  summary    String?
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model PrakritiAssessment {
  id           String   @id @default(uuid())
  patientId    String
  answer1      String
  answer2      String
  answer3      String
  answer4      String
  answer5      String
  answer6      String
  answer7      String
  answer8      String
  vataScore    Int
  pittaScore   Int
  kaphaScore   Int
  primaryDosha String
  timeSpentSec Int?
  createdAt    DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model HospitalStaff {
  id                String            @id @default(uuid())
  email             String            @unique
  password          String
  name              String
  age               Int?
  dateOfBirth       DateTime?
  gender            String?
  role              StaffRole
  hospitalId        String
  createdAt         DateTime          @default(now())
  appointmentsAsDoc Appointment[]
  doctorProfile     DoctorProfile?
  hospital          Hospital          @relation(fields: [hospitalId], references: [id])
  therapistProfile  TherapistProfile?
}

model DoctorProfile {
  id            String        @id @default(uuid())
  specialty     String
  experienceYrs Int
  qualifications String[]     @default([])
  locality      String?
  certificates  String?
  previousWork  String?
  extraInfo     String?
  languages     String[]      @default([])
  caseSummaries String[]      @default([])
  education     String[]      @default([])
  isAvailable   Boolean       @default(true)
  departmentId  String?
  staffId       String        @unique
  department    Department?   @relation(fields: [departmentId], references: [id])
  staff         HospitalStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model TherapistProfile {
  id             String        @id @default(uuid())
  staffId        String        @unique
  certifications String[]      @default([])
  staff          HospitalStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Hospital {
  id      String          @id @default(uuid())
  name    String
  address String?
  staff   HospitalStaff[]
}

model Department {
  id          String          @id @default(uuid())
  name        String
  description String?
  doctors     DoctorProfile[]
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  doctorId        String
  scheduledAt     DateTime
  status          AppointmentStatus @default(SCHEDULED)
  problemDescription String?
  patientSymptoms String?
  severity        String?
  duration        String?
  aiSummary       String?
  createdAt       DateTime          @default(now())
  dietChart       Json?
  doctorNotes     String?
  isCompleted     Boolean           @default(false)
  medications     Json?
  routinePlan     Json?
  paymentStatus   String            @default("PENDING")
  doctor          HospitalStaff     @relation(fields: [doctorId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
}

enum StaffRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
  NURSE
  THERAPIST
  BILLING
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
